# general
alias ls='eza -s type --group-directories-first'
alias op=open
alias opn=open
alias oepn=open
alias chrome='open -a "Google Chrome"'

# scripts
alias canonical='${HOME}/.zsh/python/get_canonical.py'
alias decimal='${HOME}/.zsh/python/get_decimal.py'

# javascript
alias update-node-lts='nvm install "lts/*" --reinstall-packages-from="$(nvm current)"'
alias update-node='nvm install node --reinstall-packages-from=node'
alias update-npm='npm install -g npm@latest'

# python
alias vact='source .venv/bin/activate'
alias python=python3
alias ipython='uv run --with ipython ipython'

# bioinformatics
alias pymol='/opt/homebrew/Caskroom/miniconda/base/envs/pymol-env/bin/pymol'

# clipboard
alias unformat='pbpaste | pbcopy'

# networking
alias tailscale='/Applications/Tailscale.app/Contents/MacOS/Tailscale'
alias ts='tailscale'

# zellij
sshz() {
  command ssh "$@"
  printf '\e[?1000l\e[?1002l\e[?1003l\e[?1006l'
  stty sane 2>/dev/null
}
alias zj1='zellij --layout ~/.config/zellij/layouts/1.kdl'
alias zj2x2='zellij --layout ~/.config/zellij/layouts/2x2.kdl'
alias zj2x4='zellij --layout ~/.config/zellij/layouts/2x4.kdl'
alias zj4x2='zellij --layout ~/.config/zellij/layouts/4x2.kdl'

# podman
alias podman-compose='uv run podman-compose'
